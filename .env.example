# ──── Variables de Entorno — Secure Workspace ────
# ⚠️ INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. NO necesitas cambiar NADA para desarrollo local
# 3. El archivo .env NUNCA se sube al repositorio (está en .gitignore)

# Base de datos PostgreSQL
POSTGRES_USER=securews
POSTGRES_PASSWORD=cambia_esta_contraseña_segura
POSTGRES_DB=securews
DATABASE_URL=postgresql://securews:cambia_esta_contraseña_segura@postgres:5432/securews

# JWT - Clave secreta para firmar tokens
JWT_SECRET_KEY=genera_una_clave_secreta_segura_aqui

# Redis
REDIS_URL=redis://redis:6379/0
