# ──── .gitignore — Secure Workspace ────

# Variables de entorno (secretos)
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
dist/
build/

# Node.js / Frontend
node_modules/
frontend/dist/

# Base de datos de tests
*.db
test.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
